{
  "name": "local-llm-review",
  "displayName": "Local LLM Review",
  "description": "Review local git changes with inline comments and export to clipboard",
  "version": "0.0.5",
  "publisher": "danielroos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RoosDaniel/local-review-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["workspaceContains:.git"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "local-review",
          "title": "Local Review",
          "icon": "$(git-compare)"
        }
      ]
    },
    "views": {
      "local-review": [
        {
          "id": "localReview.commits",
          "name": "Commits"
        },
        {
          "id": "localReview.files",
          "name": "Changed Files"
        },
        {
          "id": "localReview.comments",
          "name": "Comments"
        }
      ]
    },
    "commands": [
      {
        "command": "localReview.refresh",
        "title": "Refresh",
        "category": "Local Review",
        "icon": "$(refresh)"
      },
      {
        "command": "localReview.copyReview",
        "title": "Copy Review to Clipboard",
        "category": "Local Review",
        "icon": "$(clippy)"
      },
      {
        "command": "localReview.selectAll",
        "title": "Select All",
        "category": "Local Review",
        "icon": "$(check-all)"
      },
      {
        "command": "localReview.deselectAll",
        "title": "Deselect All",
        "category": "Local Review",
        "icon": "$(close-all)"
      },
      {
        "command": "localReview.toggleCommit",
        "title": "Toggle Commit",
        "category": "Local Review"
      },
      {
        "command": "localReview.openDiff",
        "title": "Open Diff",
        "category": "Local Review"
      },
      {
        "command": "localReview.clearComments",
        "title": "Clear All Comments",
        "category": "Local Review",
        "icon": "$(trash)"
      },
      {
        "command": "localReview.createComment",
        "title": "Save",
        "category": "Local Review"
      },
      {
        "command": "localReview.deleteComment",
        "title": "Delete Comment",
        "category": "Local Review",
        "icon": "$(trash)"
      },
      {
        "command": "localReview.goToComment",
        "title": "Go to Comment",
        "category": "Local Review"
      },
      {
        "command": "localReview.deleteCommentFromTree",
        "title": "Delete",
        "category": "Local Review",
        "icon": "$(trash)"
      },
      {
        "command": "localReview.copyComment",
        "title": "Copy to Clipboard",
        "category": "Local Review",
        "icon": "$(clippy)"
      },
      {
        "command": "localReview.editComment",
        "title": "Edit",
        "category": "Local Review",
        "icon": "$(edit)"
      },
      {
        "command": "localReview.saveEdit",
        "title": "Save",
        "category": "Local Review",
        "icon": "$(check)"
      },
      {
        "command": "localReview.cancelEdit",
        "title": "Cancel",
        "category": "Local Review",
        "icon": "$(close)"
      },
      {
        "command": "localReview.copyCommentInline",
        "title": "Copy to Clipboard",
        "category": "Local Review",
        "icon": "$(clippy)"
      },
      {
        "command": "localReview.copyDraft",
        "title": "Copy",
        "category": "Local Review",
        "icon": "$(clippy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "localReview.refresh",
          "when": "view == localReview.commits",
          "group": "navigation@3"
        },
        {
          "command": "localReview.deselectAll",
          "when": "view == localReview.commits",
          "group": "navigation@2"
        },
        {
          "command": "localReview.selectAll",
          "when": "view == localReview.commits",
          "group": "navigation@1"
        },
        {
          "command": "localReview.copyReview",
          "when": "view == localReview.comments",
          "group": "navigation@1"
        },
        {
          "command": "localReview.clearComments",
          "when": "view == localReview.comments",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "localReview.copyComment",
          "when": "view == localReview.comments",
          "group": "inline"
        },
        {
          "command": "localReview.deleteCommentFromTree",
          "when": "view == localReview.comments",
          "group": "inline"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "localReview.createComment",
          "group": "inline@1",
          "when": "commentController == localReview && commentThreadIsEmpty"
        },
        {
          "command": "localReview.copyDraft",
          "group": "inline@2",
          "when": "commentController == localReview && commentThreadIsEmpty"
        }
      ],
      "comments/comment/title": [
        {
          "command": "localReview.editComment",
          "group": "inline@1",
          "when": "commentController == localReview"
        },
        {
          "command": "localReview.copyCommentInline",
          "group": "inline@2",
          "when": "commentController == localReview"
        },
        {
          "command": "localReview.deleteComment",
          "group": "inline@3",
          "when": "commentController == localReview"
        }
      ],
      "comments/comment/context": [
        {
          "command": "localReview.saveEdit",
          "group": "inline@1",
          "when": "commentController == localReview"
        },
        {
          "command": "localReview.cancelEdit",
          "group": "inline@2",
          "when": "commentController == localReview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
